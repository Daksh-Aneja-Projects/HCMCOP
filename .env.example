# ---------------------------------------------------------------------------
# HCM Autopilot Agent — environment configuration
# Copy this file to `.env` and fill in your values. NEVER commit `.env`.
# ---------------------------------------------------------------------------

# Required: your Qwen Cloud (DashScope international) API key.
# Get one at https://dashscope.console.aliyun.com/
QWEN_CLOUD_API_KEY=your-qwen-cloud-api-key-here

# Optional: override the default models (defaults shown).
# QWEN_PRIMARY_MODEL=qwen-plus
# QWEN_FALLBACK_MODEL=qwen-turbo

# Optional: override the API base URL. Production uses Qwen Cloud (the default).
# For LOCAL TESTING against an Ollama Qwen-Coder model instead, set:
#   QWEN_CLOUD_API_KEY=ollama
#   QWEN_BASE_URL=http://localhost:11434/v1
#   QWEN_PRIMARY_MODEL=qwen2.5-coder:7b
#   QWEN_FALLBACK_MODEL=qwen2.5-coder:7b
# QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
